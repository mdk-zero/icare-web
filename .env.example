# =================================================================
# iCARE++ environment variables
# Copy this file to `.env.local` and fill in real values.
# =================================================================

# --- Google OAuth (Web application client) -----------------------------
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# --- Supabase -----------------------------------------------------------
# Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Session signing secret ---------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- SMTP / personal email (transactional emails) -----------------------
# Example uses Gmail. Generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=linuxadona17@gmail.com
SMTP_FROM_NAME=iCARE++
# Set to true to send real emails via SMTP in development.
SMTP_SEND_IN_DEV=true
